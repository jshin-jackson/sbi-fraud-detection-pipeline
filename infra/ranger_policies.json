          "isExcludes": false,
          "isRecursive": false
        }
      },
      "policyItems": [
        {
          "users": ["systest"],
          "groups": [],
          "accesses": [
            { "type": "publish", "isAllowed": true },
            { "type": "describe", "isAllowed": true }
          ],
          "conditions": []
        }
      ]
    },

    {
